{
  "name": "technicasino",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:realtime": "pnpm --filter technicasino-realtime dev",
    "dev:api": "cd apps/api && cargo watch -x run",
    "dev:all": "concurrently \"pnpm dev:api\" \"pnpm dev:realtime\" \"pnpm dev:web\"",
    "build:api": "cd apps/api && cargo build --release",
    "build:web": "pnpm --filter web build",
    "db:up": "docker compose -f infrastructure/docker-compose.yml up -d",
    "db:down": "docker compose -f infrastructure/docker-compose.yml down",
    "db:migrate": "cd apps/api && sqlx migrate run"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
