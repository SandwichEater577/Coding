## 3. Building the Model — Step by Step

### 3.1 Neurons & Activation Functions

A neuron computes: `output = activation(dot(weights, inputs) + bias)`

**Implement these activations (no imports):**

```python
# ── Python ──

def my_exp(x):
    """Taylor series for e^x, 30 terms for decent precision."""
    result = 1.0
    term = 1.0
    for i in range(1, 30):
        term *= x / i
        result += term
    return result

def sigmoid(x):
    if x >= 0:
        ex = my_exp(-x)
        return 1.0 / (1.0 + ex)
    else:
        ex = my_exp(x)
        return ex / (1.0 + ex)

def relu(x):
    return x if x > 0.0 else 0.0

def tanh_activation(x):
    if x > 20.0:
        return 1.0
    if x < -20.0:
        return -1.0
    e2x = my_exp(2.0 * x)
    return (e2x - 1.0) / (e2x + 1.0)

def softmax(values):
    max_val = values[0]
    for v in values:
        if v > max_val:
            max_val = v
    exps = []
    total = 0.0
    for v in values:
        e = my_exp(v - max_val)
        exps.append(e)
        total += e
    return [e / total for e in exps]
```

```javascript
// ── JavaScript ──

function myExp(x) {
  let result = 1.0,
    term = 1.0;
  for (let i = 1; i < 30; i++) {
    term *= x / i;
    result += term;
  }
  return result;
}

function sigmoid(x) {
  if (x >= 0) {
    let ex = myExp(-x);
    return 1.0 / (1.0 + ex);
  } else {
    let ex = myExp(x);
    return ex / (1.0 + ex);
  }
}

function relu(x) {
  return x > 0 ? x : 0;
}

function tanhActivation(x) {
  if (x > 20) return 1.0;
  if (x < -20) return -1.0;
  let e2x = myExp(2.0 * x);
  return (e2x - 1.0) / (e2x + 1.0);
}
```

```rust
// ── Rust ──

fn my_exp(x: f64) -> f64 {
    let mut result = 1.0_f64;
    let mut term = 1.0_f64;
    for i in 1..30 {
        term *= x / i as f64;
        result += term;
    }
    result
}

fn sigmoid(x: f64) -> f64 {
    if x >= 0.0 {
        let ex = my_exp(-x);
        1.0 / (1.0 + ex)
    } else {
        let ex = my_exp(x);
        ex / (1.0 + ex)
    }
}

fn relu(x: f64) -> f64 { if x > 0.0 { x } else { 0.0 } }
```

### 3.2 Layers

A layer is a collection of neurons. Represented as a **weight matrix** + **bias vector**.

```python
# ── Python ──

# PRNG (no imports!)
_rng_state = 42

def lcg_random():
    global _rng_state
    _rng_state = (1664525 * _rng_state + 1013904223) % (2**32)
    return _rng_state / (2**32)

def random_normal():
    """Box-Muller transform using our LCG — no imports."""
    u1 = lcg_random()
    u2 = lcg_random()
    while u1 == 0.0:
        u1 = lcg_random()
    # manual sqrt and log needed:
    mag = my_sqrt(-2.0 * my_log(u1))
    z = mag * my_cos(2.0 * 3.14159265358979 * u2)
    return z

def my_sqrt(x):
    if x <= 0.0:
        return 0.0
    guess = x
    for _ in range(50):
        guess = (guess + x / guess) / 2.0
    return guess

def my_log(x):
    """Natural log via Newton's method: find y where e^y = x."""
    if x <= 0:
        return -999999.0  # undefined, return very negative
    y = 0.0
    for _ in range(100):
        ey = my_exp(y)
        y = y - (ey - x) / ey
    return y

def my_cos(x):
    """Taylor series for cos(x)."""
    result = 1.0
    term = 1.0
    for i in range(1, 20):
        term *= -x * x / ((2*i - 1) * (2*i))
        result += term
    return result

class Layer:
    def __init__(self, input_size, output_size):
        # He initialization: scale = sqrt(2 / input_size)
        scale = my_sqrt(2.0 / input_size)
        self.weights = []
        for i in range(output_size):
            row = []
            for j in range(input_size):
                row.append(random_normal() * scale)
            self.weights.append(row)
        self.biases = [0.0] * output_size
        # For storing gradients
        self.weight_grads = [[0.0]*input_size for _ in range(output_size)]
        self.bias_grads = [0.0] * output_size
        # For storing activations (needed for backprop)
        self.last_input = None
        self.last_output = None

    def forward(self, inputs):
        self.last_input = inputs[:]
        outputs = []
        for i in range(len(self.weights)):
            total = self.biases[i]
            for j in range(len(inputs)):
                total += self.weights[i][j] * inputs[j]
            outputs.append(total)
        self.last_output = outputs[:]
        return outputs
```

### 3.3 Forward Pass

The forward pass chains layers together, applying activations between them:

```python
class NeuralNetwork:
    def __init__(self, layer_sizes, activation='relu'):
        """
        layer_sizes: list like [input_dim, hidden1, hidden2, ..., output_dim]
        Example: [768, 512, 256, 128, vocab_size]
        """
        self.layers = []
        self.activation_name = activation
        for i in range(len(layer_sizes) - 1):
            self.layers.append(Layer(layer_sizes[i], layer_sizes[i+1]))

    def activate(self, values, is_output=False):
        if is_output:
            return softmax(values)
        if self.activation_name == 'relu':
            return [relu(v) for v in values]
        elif self.activation_name == 'tanh':
            return [tanh_activation(v) for v in values]
        elif self.activation_name == 'sigmoid':
            return [sigmoid(v) for v in values]
        return values

    def forward(self, inputs):
        """Run input through all layers."""
        current = inputs
        for i, layer in enumerate(self.layers):
            current = layer.forward(current)
            is_last = (i == len(self.layers) - 1)
            current = self.activate(current, is_output=is_last)
        return current
```

### 3.4 Loss Functions

```python
def cross_entropy_loss(predicted, target_index):
    """
    predicted: list of probabilities from softmax
    target_index: integer, the correct class
    """
    p = predicted[target_index]
    if p <= 0.0:
        p = 1e-15
    return -my_log(p)

def mse_loss(predicted, target):
    """Mean Squared Error for regression tasks."""
    total = 0.0
    for i in range(len(predicted)):
        diff = predicted[i] - target[i]
        total += diff * diff
    return total / len(predicted)
```

### 3.5 Backpropagation

This is the hardest part (~2000+ lines when done properly). The core idea: compute how much each weight contributed to the error, then adjust.

```python
def backward(self, predicted, target_index):
    """
    Backpropagate error through the network.
    Uses chain rule: dL/dw = dL/da * da/dz * dz/dw
    """
    num_layers = len(self.layers)

    # ── Step 1: Output layer gradient ──
    # For softmax + cross-entropy, the gradient simplifies to:  (predicted - target)
    output_grad = predicted[:]
    output_grad[target_index] -= 1.0  # subtract 1 from the true class

    # ── Step 2: Walk backwards through layers ──
    current_grad = output_grad

    for layer_idx in range(num_layers - 1, -1, -1):
        layer = self.layers[layer_idx]
        inp = layer.last_input
        out = layer.last_output

        # Apply activation derivative (skip for output layer — already handled)
        if layer_idx < num_layers - 1:
            act_grad = []
            for i in range(len(out)):
                if self.activation_name == 'relu':
                    act_grad.append(1.0 if out[i] > 0 else 0.0)
                elif self.activation_name == 'sigmoid':
                    s = sigmoid(out[i])
                    act_grad.append(s * (1.0 - s))
                elif self.activation_name == 'tanh':
                    t = tanh_activation(out[i])
                    act_grad.append(1.0 - t * t)
                else:
                    act_grad.append(1.0)
            current_grad = [current_grad[i] * act_grad[i]
                            for i in range(len(current_grad))]

        # ── Compute weight & bias gradients ──
        for i in range(len(layer.weights)):
            layer.bias_grads[i] = current_grad[i]
            for j in range(len(layer.weights[i])):
                layer.weight_grads[i][j] = current_grad[i] * inp[j]

        # ── Compute gradient for next (earlier) layer ──
        if layer_idx > 0:
            next_grad = [0.0] * len(inp)
            for j in range(len(inp)):
                for i in range(len(layer.weights)):
                    next_grad[j] += layer.weights[i][j] * current_grad[i]
            current_grad = next_grad
```

### 3.6 Weight Updates (Gradient Descent)

```python
def update_weights(self, learning_rate):
    """Simple SGD update."""
    for layer in self.layers:
        for i in range(len(layer.weights)):
            layer.biases[i] -= learning_rate * layer.bias_grads[i]
            for j in range(len(layer.weights[i])):
                layer.weights[i][j] -= learning_rate * layer.weight_grads[i][j]

def update_weights_adam(self, learning_rate=0.001, beta1=0.9, beta2=0.999, epsilon=1e-8):
    """
    Adam optimizer — implemented from scratch.
    Each layer needs extra state: m (1st moment), v (2nd moment), t (timestep).
    This alone is ~200 lines when properly implemented for all layers.
    """
    # Initialize moment estimates on first call
    if not hasattr(self, '_adam_t'):
        self._adam_t = 0
        for layer in self.layers:
            layer.m_w = [[0.0]*len(row) for row in layer.weights]
            layer.v_w = [[0.0]*len(row) for row in layer.weights]
            layer.m_b = [0.0] * len(layer.biases)
            layer.v_b = [0.0] * len(layer.biases)

    self._adam_t += 1
    t = self._adam_t

    for layer in self.layers:
        for i in range(len(layer.weights)):
            # Bias update
            layer.m_b[i] = beta1 * layer.m_b[i] + (1-beta1) * layer.bias_grads[i]
            layer.v_b[i] = beta2 * layer.v_b[i] + (1-beta2) * layer.bias_grads[i]**2
            m_hat = layer.m_b[i] / (1 - pow_manual(beta1, t))
            v_hat = layer.v_b[i] / (1 - pow_manual(beta2, t))
            layer.biases[i] -= learning_rate * m_hat / (my_sqrt(v_hat) + epsilon)

            for j in range(len(layer.weights[i])):
                g = layer.weight_grads[i][j]
                layer.m_w[i][j] = beta1 * layer.m_w[i][j] + (1-beta1) * g
                layer.v_w[i][j] = beta2 * layer.v_w[i][j] + (1-beta2) * g * g
                m_hat = layer.m_w[i][j] / (1 - pow_manual(beta1, t))
                v_hat = layer.v_w[i][j] / (1 - pow_manual(beta2, t))
                layer.weights[i][j] -= learning_rate * m_hat / (my_sqrt(v_hat) + epsilon)

def pow_manual(base, exp):
    result = 1.0
    for _ in range(exp):
        result *= base
    return result
```

### 3.7 Training Loop

```python
def train(network, data, labels, epochs, learning_rate):
    """
    data:   list of input vectors  [[f1,f2,...], [f1,f2,...], ...]
    labels: list of target indices [3, 0, 7, ...]
    """
    for epoch in range(epochs):
        total_loss = 0.0
        correct = 0

        for i in range(len(data)):
            # Forward
            output = network.forward(data[i])

            # Loss
            loss = cross_entropy_loss(output, labels[i])
            total_loss += loss

            # Accuracy check
            pred = 0
            for k in range(len(output)):
                if output[k] > output[pred]:
                    pred = k
            if pred == labels[i]:
                correct += 1

            # Backward
            network.backward(output, labels[i])

            # Update
            network.update_weights(learning_rate)

        avg_loss = total_loss / len(data)
        accuracy = correct / len(data) * 100.0

        # Print progress (print is a builtin, not an import)
        print("Epoch " + str(epoch+1) + "/" + str(epochs)
              + "  loss=" + str(avg_loss)
              + "  acc=" + str(accuracy) + "%")
```

