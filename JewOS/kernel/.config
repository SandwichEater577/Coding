# JewOS minimal Linux kernel config for QEMU x86_64
# Based on a stripped-down Arch Linux kernel config.
# To use: copy this to your linux source tree as .config, then run `make olddefconfig`

#
# General setup
#
CONFIG_LOCALVERSION="-jewos"
CONFIG_DEFAULT_HOSTNAME="jewos"
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_AUDIT=n
CONFIG_CGROUPS=n
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_MULTIUSER=y
CONFIG_SYSFS=y
CONFIG_PROC_FS=y
CONFIG_TMPFS=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y

#
# Processor type and features (x86_64)
#
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_KVM_GUEST=y

#
# Power management (minimal — no ACPI sleep states needed)
#
CONFIG_ACPI=y
CONFIG_ACPI_BUTTON=n
CONFIG_ACPI_FAN=n
CONFIG_ACPI_THERMAL=n
CONFIG_CPU_FREQ=n

#
# Bus options
#
CONFIG_PCI=y
CONFIG_PCI_MSI=y

#
# Networking (minimal — just loopback + basic TCP/IP for future use)
#
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=n
CONFIG_NETFILTER=n
CONFIG_WIRELESS=n
CONFIG_NET_9P=n

#
# Device drivers
#

# Virtio (QEMU)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_INPUT=y
CONFIG_HW_RANDOM_VIRTIO=y

# Block devices
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_LOOP=y

# SCSI (needed for virtio-blk in some configs)
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y

# Input
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_INPUT_MOUSE=n
CONFIG_INPUT_TOUCHSCREEN=n

# Character devices
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_UNIX98_PTYS=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# Graphics (framebuffer only — no GPU, just for TUI)
CONFIG_FB=y
CONFIG_FB_VESA=y
CONFIG_FB_EFI=n
CONFIG_VGA_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_DRM=n

# USB (minimal)
CONFIG_USB=n

# Sound
CONFIG_SOUND=n

# Firmware
CONFIG_FW_LOADER=y

#
# Filesystems
#
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_FUSE_FS=n
CONFIG_OVERLAY_FS=n
CONFIG_MSDOS_FS=n
CONFIG_VFAT_FS=n
CONFIG_NFS_FS=n

#
# Initramfs/initrd support
#
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_RD_XZ=y

#
# Kernel hacking (disable for production, enable for debugging)
#
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y
CONFIG_MAGIC_SYSRQ=y
CONFIG_DEBUG_KERNEL=n

#
# Security (minimal)
#
CONFIG_SECURITY=n
CONFIG_SECURITY_SELINUX=n
CONFIG_SECURITY_APPARMOR=n

#
# Modules
#
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
